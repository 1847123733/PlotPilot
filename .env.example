# LLM 供应商选择：
# - anthropic: Claude 官方/代理
# - openai/openapi/ark/deepseek: OpenAI 兼容接口
LLM_PROVIDER=anthropic

# Anthropic 配置（LLM_PROVIDER=anthropic 时生效）
# 与 Cursor「.claude/settings.json」里同名项对齐时，请复制到系统环境或本文件，勿提交密钥。
# ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_TIMEOUT=300

# OpenAI 兼容配置（LLM_PROVIDER=openai/openapi/ark/deepseek 时生效）
# 兼容 OpenAI / DeepSeek / ByteDance Ark / 各类 OpenAPI 网关
# OPENAI_API_KEY=
# OPENAPI_API_KEY=
# OPENAI_BASE_URL=
# OPENAPI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini
# OPENAPI_MODEL=gpt-4o-mini
# OPENAI_TIMEOUT=300
# OPENAPI_TIMEOUT=300

# Ark/DeepSeek 兼容配置（同样走 OpenAI 兼容 Provider）
# ARK_API_KEY=
# ARK_BASE_URL=https://api.deepseek.com/v1
# ARK_MODEL=deepseek-chat
# ARK_TIMEOUT=120

# 可选默认篇幅
# AITEXT_DEFAULT_CHAPTERS=5
# AITEXT_DEFAULT_WORDS_PER_CHAPTER=2500
# AITEXT_SUMMARY_MAX_CHAPTERS=5

# 日志配置
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/aitext.log
